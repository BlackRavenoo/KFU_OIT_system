{
  "db_name": "PostgreSQL",
  "query": "\n\t\tSELECT\n\t\t\ta.id,\n\t\t\ta.name,\n\t\t\ta.description,\n\t\t\ta.serial_number,\n\t\t\ta.inventory_number,\n\t\t\tjson_build_object(\n\t\t\t\t'id', ast.id,\n\t\t\t\t'name', ast.name,\n\t\t\t\t'color', ast.color\n\t\t\t) AS \"status!: Json<Status>\",\n\t\t\ta.location,\n\t\t\ta.assigned_to,\n\t\t\tjsonb_build_object(\n\t\t\t\t'id', am.id,\n\t\t\t\t'name', am.name,\n\t\t\t\t'category', jsonb_build_object(\n\t\t\t\t\t'id', ac.id,\n\t\t\t\t\t'name', ac.name,\n\t\t\t\t\t'color', ac.color,\n\t\t\t\t\t'notes', ac.notes\n\t\t\t\t)\n\t\t\t) AS \"model!: Json<Model>\",\n\t\t\ta.ip AS \"ip: IpAddr\",\n\t\t\ta.mac,\n\t\t\ta.photo_key,\n\t\t\ta.commission_date,\n\t\t\ta.decommission_date,\n\t\t\tta.comment\n\t\tFROM ticket_assets ta\n\t\tJOIN assets a ON a.id = ta.asset_id\n\t\tJOIN asset_statuses ast ON ast.id = a.status\n\t\tJOIN asset_models am ON am.id = a.model_id\n\t\tJOIN asset_categories ac ON ac.id = am.category\n\t\tWHERE ta.ticket_id = $1\n\t\tORDER BY a.id DESC\n\t\t",
